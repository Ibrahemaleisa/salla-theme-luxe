{# Comments Component - Used in product pages and blog posts #}
<div class="comments-section" id="comments">
  <h3 class="text-xl font-bold text-[var(--color-primary)] dark:text-white mb-6">
    التعليقات
    {% if comments.total %}
    <span class="text-base font-normal text-[var(--color-muted)] ms-2">({{ comments.total }})</span>
    {% endif %}
  </h3>

  {# Add Comment Form #}
  {% if store.customer.is_logged_in %}
  <div class="card-flat rounded-[var(--border-radius-card)] p-5 mb-8">
    <h4 class="font-semibold text-sm mb-4">أضف تعليقك</h4>
    <form action="{{ comments.submit_url | default('#') }}" method="POST" class="space-y-4">
      <input type="hidden" name="_token" value="{{ csrf_token }}">

      {# Rating #}
      <div class="form-group">
        <label class="block text-sm font-medium mb-2">تقييمك</label>
        <div class="flex gap-1" role="radiogroup" aria-label="التقييم">
          {% for i in 1..5 %}
          <label class="cursor-pointer">
            <input type="radio" name="rating" value="{{ i }}" class="sr-only" {{ i == 5 ? 'checked' : '' }}>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-gray-300 hover:text-yellow-400 transition-colors peer-checked:text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          </label>
          {% endfor %}
        </div>
      </div>

      <div class="form-group">
        <label for="comment-text">التعليق</label>
        <textarea id="comment-text" name="comment" rows="4" class="form-control" placeholder="شاركنا رأيك..." required minlength="10"></textarea>
      </div>
      <div class="flex justify-end">
        <button type="submit" class="btn-primary btn px-8">إرسال التعليق</button>
      </div>
    </form>
  </div>
  {% else %}
  <div class="card-flat rounded-[var(--border-radius-card)] p-5 mb-8 text-center">
    <p class="text-sm text-[var(--color-muted)] mb-3">سجّل دخولك لإضافة تعليق</p>
    <a href="{{ store.customer.login_url }}" class="btn-primary btn-sm btn">تسجيل الدخول</a>
  </div>
  {% endif %}

  {# Comments List #}
  {% if comments.items %}
  <div class="space-y-5" aria-label="قائمة التعليقات">
    {% for comment in comments.items %}
    <div class="flex gap-4" itemscope itemtype="https://schema.org/Review">
      <div class="w-10 h-10 rounded-full bg-[var(--color-primary)]/10 flex items-center justify-center text-[var(--color-primary)] font-bold text-sm flex-shrink-0">
        {{ comment.author | first | upper }}
      </div>
      <div class="flex-1">
        <div class="flex items-start justify-between gap-2 flex-wrap">
          <div>
            <span class="font-semibold text-sm" itemprop="author" itemscope itemtype="https://schema.org/Person"><span itemprop="name">{{ comment.author }}</span></span>
            <time class="text-xs text-[var(--color-muted)] ms-2" itemprop="datePublished">{{ comment.date }}</time>
          </div>
          {% if comment.rating %}
          <div class="flex gap-0.5" itemprop="reviewRating" itemscope itemtype="https://schema.org/Rating">
            <meta itemprop="ratingValue" content="{{ comment.rating }}">
            {% for i in 1..5 %}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 {{ i <= comment.rating ? 'text-yellow-400' : 'text-gray-300' }}" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            {% endfor %}
          </div>
          {% endif %}
        </div>
        <p class="text-sm text-[var(--color-muted)] mt-2 leading-relaxed" itemprop="description">{{ comment.content }}</p>
        {% if comment.store_reply %}
        <div class="mt-3 ms-4 ps-4 border-s-2 border-[var(--color-primary)]">
          <p class="text-xs font-semibold text-[var(--color-primary)] mb-1">رد {{ store.name }}:</p>
          <p class="text-sm text-[var(--color-muted)]">{{ comment.store_reply }}</p>
        </div>
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </div>
  {% else %}
  <div class="text-center py-10 text-[var(--color-muted)]">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 mx-auto mb-3 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
    <p class="text-sm">لا توجد تعليقات بعد. كن أول من يعلّق!</p>
  </div>
  {% endif %}
</div>
