{# Reusable Product Card Component #}
{% set card_style = theme.settings.get('product_card_style') | default('default') %}
{% set show_wishlist = theme.settings.get('show_product_wishlist') | default(true) %}
{% set show_quick_view = theme.settings.get('show_product_quick_view') | default(true) %}

<article
  class="product-card group"
  itemscope
  itemtype="https://schema.org/Product"
>
  {# Image Wrapper #}
  <div class="product-card__image-wrap">

    {# Main Product Image #}
    <a href="{{ product.url }}" class="block w-full h-full" tabindex="-1" aria-hidden="true">
      <img
        src="{{ product.thumbnail }}"
        alt="{{ product.name }}"
        class="product-card__image"
        loading="lazy"
        itemprop="image"
        width="400"
        height="400"
      >
      {# Hover Second Image #}
      {% if product.images | length > 1 %}
      <img
        src="{{ product.images[1].url }}"
        alt="{{ product.name }}"
        class="product-card__image absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
        loading="lazy"
      >
      {% endif %}
    </a>

    {# Badges #}
    <div class="product-card__badges" aria-label="شارات المنتج">
      {% if product.is_new %}
      <span class="product-card__badge product-card__badge--new">جديد</span>
      {% endif %}
      {% if product.discount_percent > 0 %}
      <span class="product-card__badge product-card__badge--sale">-{{ product.discount_percent }}%</span>
      {% endif %}
      {% if product.is_out_of_stock %}
      <span class="product-card__badge product-card__badge--out">نفذ المخزون</span>
      {% endif %}
      {% if product.is_featured %}
      <span class="product-card__badge product-card__badge--featured">مميز</span>
      {% endif %}
    </div>

    {# Action Buttons #}
    <div class="product-card__actions" aria-label="إجراءات سريعة">
      {% if show_wishlist %}
      <button
        class="product-card__action-btn"
        aria-label="إضافة إلى المفضلة"
        :class="{ 'active': $store.wishlist.has('{{ product.id }}') }"
        @click="$store.wishlist.toggle('{{ product.id }}')"
        title="المفضلة"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
        </svg>
      </button>
      {% endif %}

      {% if show_quick_view %}
      <button
        class="product-card__action-btn"
        aria-label="عرض سريع"
        data-quick-view="{{ product.id }}"
        title="عرض سريع"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
        </svg>
      </button>
      {% endif %}
    </div>

    {# Add to Cart Overlay (for out of stock) #}
    {% if product.is_out_of_stock %}
    <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
      <span class="bg-white text-gray-800 text-xs font-bold px-4 py-2 rounded-full">نفذ المخزون</span>
    </div>
    {% endif %}
  </div>

  {# Card Body #}
  <div class="product-card__body">
    {# Brand #}
    {% if product.brand %}
    <p class="product-card__brand" itemprop="brand" itemscope itemtype="https://schema.org/Brand">
      <span itemprop="name">{{ product.brand.name }}</span>
    </p>
    {% endif %}

    {# Product Name #}
    <h3 class="product-card__name" itemprop="name">
      <a href="{{ product.url }}" class="hover:text-[var(--color-primary)] transition-colors">
        {{ product.name }}
      </a>
    </h3>

    {# Rating #}
    {% if product.rating %}
    <div class="product-card__rating" itemprop="aggregateRating" itemscope itemtype="https://schema.org/AggregateRating">
      <div class="product-card__stars" aria-hidden="true">
        {% for i in 1..5 %}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 {{ i <= product.rating.average ? 'text-yellow-400' : 'text-gray-300' }}" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
        {% endfor %}
      </div>
      {% if product.rating.count %}
      <span class="product-card__reviews" itemprop="reviewCount">({{ product.rating.count }})</span>
      {% endif %}
      <meta itemprop="ratingValue" content="{{ product.rating.average }}">
    </div>
    {% endif %}

    {# Price & Add to Cart #}
    <div class="product-card__price-wrap" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
      <div>
        <span class="product-card__price" itemprop="price" content="{{ product.price.amount }}">
          {{ product.price.formatted }}
        </span>
        {% if product.old_price %}
        <span class="product-card__old-price">{{ product.old_price.formatted }}</span>
        {% endif %}
      </div>

      {% if not product.is_out_of_stock %}
      <button
        class="product-card__add-btn"
        data-add-to-cart="{{ product.id }}"
        aria-label="إضافة {{ product.name }} إلى السلة"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
        </svg>
      </button>
      {% endif %}
    </div>
  </div>
</article>
