{# Cart Drawer #}
<aside
  data-cart-drawer
  class="drawer drawer--closed"
  aria-label="سلة التسوق"
  role="dialog"
  aria-modal="true"
>
  <div class="drawer__header">
    <div class="flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
      </svg>
      <h2 class="drawer__title">سلة التسوق</h2>
      <span class="badge badge-gray ms-1" x-text="$store.cart.count || '{{ store.cart.count }}'">{{ store.cart.count }}</span>
    </div>
    <button data-cart-close class="btn-ghost btn-icon" aria-label="إغلاق السلة">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <div class="drawer__body scrollbar-thin" id="cart-drawer-body">
    {% if store.cart.count > 0 %}
    <div class="space-y-4">
      {% for item in store.cart.items %}
      <div class="flex gap-3 pb-4 border-b border-[var(--color-border)] last:border-0">
        {# Product Image #}
        <a href="{{ item.product.url }}" class="flex-shrink-0 w-20 h-20 rounded-[var(--border-radius)] overflow-hidden bg-gray-50">
          <img
            src="{{ item.product.thumbnail }}"
            alt="{{ item.product.name }}"
            class="w-full h-full object-cover"
            loading="lazy"
          >
        </a>

        {# Product Info #}
        <div class="flex-1 min-w-0">
          <a href="{{ item.product.url }}" class="text-sm font-semibold line-clamp-2 hover:text-[var(--color-primary)] transition-colors">
            {{ item.product.name }}
          </a>
          {% if item.options %}
          <p class="text-xs text-[var(--color-muted)] mt-0.5">{{ item.options | join(', ') }}</p>
          {% endif %}
          <div class="flex items-center justify-between mt-2">
            {# Quantity Control #}
            <div class="flex items-center border border-[var(--color-border)] rounded-[var(--border-radius)] overflow-hidden" data-qty-control>
              <button data-qty-dec class="w-7 h-7 flex items-center justify-center hover:bg-gray-50 dark:hover:bg-gray-700 text-sm transition-colors" aria-label="تقليل الكمية">-</button>
              <input
                data-qty-input
                type="number"
                value="{{ item.quantity }}"
                min="1"
                max="{{ item.product.quantity }}"
                class="w-8 h-7 text-center text-xs border-x border-[var(--color-border)] bg-transparent outline-none"
                aria-label="الكمية"
              >
              <button data-qty-inc class="w-7 h-7 flex items-center justify-center hover:bg-gray-50 dark:hover:bg-gray-700 text-sm transition-colors" aria-label="زيادة الكمية">+</button>
            </div>

            {# Price #}
            <p class="font-bold text-[var(--color-primary)] dark:text-white text-sm">{{ item.price.formatted }}</p>
          </div>
        </div>

        {# Remove Button #}
        <button
          class="flex-shrink-0 text-[var(--color-muted)] hover:text-red-500 transition-colors self-start"
          aria-label="حذف المنتج"
          data-remove-cart-item="{{ item.id }}"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
        </button>
      </div>
      {% endfor %}
    </div>
    {% else %}
    <div class="empty-state py-16">
      <svg xmlns="http://www.w3.org/2000/svg" class="empty-state__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
      </svg>
      <h3 class="empty-state__title">السلة فارغة</h3>
      <p class="empty-state__desc">لم تضف أي منتجات بعد</p>
      <button data-cart-close class="btn-primary btn">تصفح المنتجات</button>
    </div>
    {% endif %}
  </div>

  {% if store.cart.count > 0 %}
  <div class="drawer__footer">
    {# Order Summary #}
    <div class="space-y-2 mb-4">
      <div class="flex items-center justify-between text-sm">
        <span class="text-[var(--color-muted)]">المجموع الجزئي</span>
        <span class="font-medium">{{ store.cart.subtotal.formatted }}</span>
      </div>
      {% if store.cart.discount.amount > 0 %}
      <div class="flex items-center justify-between text-sm text-green-600">
        <span>الخصم</span>
        <span class="font-medium">- {{ store.cart.discount.formatted }}</span>
      </div>
      {% endif %}
      <div class="flex items-center justify-between text-sm">
        <span class="text-[var(--color-muted)]">الشحن</span>
        <span class="font-medium">{{ store.cart.shipping.formatted | default('يُحسب عند الدفع') }}</span>
      </div>
      <div class="flex items-center justify-between border-t border-[var(--color-border)] pt-2">
        <span class="font-bold text-base">الإجمالي</span>
        <span class="font-black text-lg text-[var(--color-primary)]">{{ store.cart.total.formatted }}</span>
      </div>
    </div>

    {# Coupon #}
    <div class="mb-4" x-data="{ open: false }">
      <button @click="open = !open" class="text-sm text-[var(--color-primary)] underline underline-offset-2">
        هل لديك كوبون خصم؟
      </button>
      <div x-show="open" x-transition class="mt-2 flex gap-2">
        <input type="text" placeholder="أدخل الكوبون" class="form-control flex-1 py-2">
        <button class="btn-outline btn-sm btn">تطبيق</button>
      </div>
    </div>

    {# CTA Buttons #}
    <div class="flex flex-col gap-2">
      <a href="{{ store.cart.checkout_url }}" class="btn-primary btn btn-full btn-lg">
        إتمام الشراء
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 rtl:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
      <a href="{{ store.cart.url }}" class="btn-ghost btn btn-full text-sm">
        عرض السلة الكاملة
      </a>
    </div>

    {# Payment Icons #}
    <div class="flex items-center justify-center gap-2 mt-4 pt-3 border-t border-[var(--color-border)]">
      {% for payment in store.payment_methods | slice(0, 6) %}
      {% if payment.icon %}
      <img src="{{ payment.icon }}" alt="{{ payment.name }}" class="h-6 w-auto object-contain" loading="lazy">
      {% endif %}
      {% endfor %}
    </div>
  </div>
  {% endif %}
</aside>
