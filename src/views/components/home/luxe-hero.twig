{# Luxe Hero Slider Component #}
{% set autoplay = component.fields.autoplay | default(true) %}
{% set speed = component.fields.autoplay_speed | default(5) %}
{% set height = theme.settings.get('hero_height') | default('full') %}

<section
  class="relative overflow-hidden
  {% if height == 'full' %}h-screen min-h-[500px] max-h-[900px]
  {% elseif height == 'large' %}h-[80vh] min-h-[400px]
  {% else %}h-[60vh] min-h-[350px]{% endif %}"
  aria-label="بانر رئيسي"
>
  <div
    class="swiper h-full"
    data-swiper="hero"
    data-autoplay="{{ autoplay ? 'true' : 'false' }}"
    data-speed="{{ speed }}"
  >
    <div class="swiper-wrapper">
      {# Slides #}
      {% set slides = [
        {
          image: component.fields.slide_1_image,
          title: component.fields.slide_1_title,
          subtitle: component.fields.slide_1_subtitle,
          btn_text: component.fields.slide_1_btn_text,
          btn_url: component.fields.slide_1_btn_url
        },
        {
          image: component.fields.slide_2_image,
          title: component.fields.slide_2_title,
          subtitle: component.fields.slide_2_subtitle,
          btn_text: component.fields.slide_2_btn_text,
          btn_url: component.fields.slide_2_btn_url
        }
      ] %}

      {% for slide in slides %}
      {% if slide.image or slide.title %}
      <div class="swiper-slide relative">
        {# Background #}
        {% if slide.image %}
        <div class="absolute inset-0">
          <img
            src="{{ slide.image }}"
            alt="{{ slide.title }}"
            class="w-full h-full object-cover"
            {% if loop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
          >
          <div class="absolute inset-0 bg-gradient-to-e from-black/60 via-black/30 to-transparent"></div>
        </div>
        {% else %}
        <div class="absolute inset-0 bg-gradient-primary"></div>
        {% endif %}

        {# Content #}
        <div class="relative h-full flex items-center">
          <div class="container mx-auto px-4">
            <div class="max-w-2xl text-white" data-animate>
              {% if slide.title %}
              <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-tight mb-4 text-balance">
                {{ slide.title }}
              </h1>
              {% endif %}
              {% if slide.subtitle %}
              <p class="text-lg md:text-xl text-white/80 mb-8 leading-relaxed max-w-lg">
                {{ slide.subtitle }}
              </p>
              {% endif %}
              {% if slide.btn_text and slide.btn_url %}
              <div class="flex items-center gap-4 flex-wrap">
                <a
                  href="{{ slide.btn_url }}"
                  class="btn-secondary btn btn-lg"
                >
                  {{ slide.btn_text }}
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 rtl:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                  </svg>
                </a>
                <a href="{{ store.products_url }}" class="text-white/80 hover:text-white text-sm font-medium underline underline-offset-4 transition-colors">
                  تصفح الكل
                </a>
              </div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
      {% endif %}
      {% endfor %}
    </div>

    {# Navigation #}
    <button class="swiper-button-prev" aria-label="السابق"></button>
    <button class="swiper-button-next" aria-label="التالي"></button>
    <div class="swiper-pagination !bottom-6"></div>
  </div>

  {# Scroll Indicator #}
  <div class="absolute bottom-8 start-1/2 -translate-x-1/2 z-10 hidden md:block animate-bounce" aria-hidden="true">
    <div class="w-6 h-10 rounded-full border-2 border-white/40 flex items-start justify-center p-1.5">
      <div class="w-1.5 h-3 rounded-full bg-white/70 animate-pulse-slow"></div>
    </div>
  </div>
</section>
