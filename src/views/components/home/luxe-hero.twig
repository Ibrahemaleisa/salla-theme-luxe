{#
  Luxe Hero - Professional Slider Component
  Fields: autoplay (boolean), slides (collection: image, title, subtitle, btn_text, btn_url)
#}
{% set autoplay = component.fields.autoplay | default(true) %}
{% set is_large  = theme.settings.get('hero_height_large') %}
{% set is_medium = theme.settings.get('hero_height_medium') %}

<section
  class="relative overflow-hidden
    {% if is_medium %}h-[60vh] min-h-[350px]
    {% elseif is_large %}h-[80vh] min-h-[400px]
    {% else %}h-screen min-h-[500px] max-h-[900px]{% endif %}"
  aria-label="البانر الرئيسي"
>
  <div
    class="swiper h-full"
    data-swiper="hero"
    data-autoplay="{{ autoplay ? 'true' : 'false' }}"
  >
    <div class="swiper-wrapper">

      {% if component.fields.slides %}
        {% for slide in component.fields.slides %}
        {# Twilight collection fields use dot-notation keys: slides.image, slides.title, etc. #}
        {% set slide_image    = slide['slides.image']    | default(null) %}
        {% set slide_title    = slide['slides.title']    | default(null) %}
        {% set slide_subtitle = slide['slides.subtitle'] | default(null) %}
        {% set slide_btn_text = slide['slides.btn_text'] | default(null) %}
        {% set slide_btn_url  = slide['slides.btn_url']  | default(null) %}

        <div class="swiper-slide relative">

          {# Background Image #}
          {% if slide_image %}
          <div class="absolute inset-0">
            <img
              src="{{ slide_image }}"
              alt="{{ slide_title | default(store.name) }}"
              class="w-full h-full object-cover"
              {% if loop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
            >
            <div class="absolute inset-0 bg-gradient-to-e from-black/65 via-black/30 to-transparent"></div>
          </div>
          {% else %}
          <div class="absolute inset-0 bg-gradient-primary"></div>
          {% endif %}

          {# Content #}
          <div class="relative h-full flex items-center">
            <div class="container mx-auto px-4">
              <div class="max-w-2xl text-white" data-animate>
                {% if slide_title %}
                <h2 class="text-4xl md:text-5xl lg:text-6xl font-black leading-tight mb-4 text-balance">
                  {{ slide_title }}
                </h2>
                {% endif %}

                {% if slide_subtitle %}
                <p class="text-lg md:text-xl text-white/80 mb-8 leading-relaxed max-w-lg">
                  {{ slide_subtitle }}
                </p>
                {% endif %}

                {% if slide_btn_text and slide_btn_url %}
                <div class="flex items-center gap-4 flex-wrap">
                  <a href="{{ slide_btn_url }}" class="btn-secondary btn btn-lg">
                    {{ slide_btn_text }}
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 rtl:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                    </svg>
                  </a>
                  <a href="{{ store.products_url }}" class="text-white/80 hover:text-white text-sm font-medium underline underline-offset-4 transition-colors">
                    تصفح الكل
                  </a>
                </div>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
        {% endfor %}

      {% else %}
        {# Fallback slide when no content configured yet #}
        <div class="swiper-slide relative">
          <div class="absolute inset-0 bg-gradient-primary"></div>
          <div class="relative h-full flex items-center justify-center text-white text-center">
            <div class="container mx-auto px-4">
              <h2 class="text-4xl md:text-5xl font-black mb-4">{{ store.name }}</h2>
              <p class="text-white/70 mb-8 text-lg">{{ store.description | truncate(120) }}</p>
              <a href="{{ store.products_url }}" class="btn-secondary btn btn-lg">تسوق الآن</a>
            </div>
          </div>
        </div>
      {% endif %}

    </div>

    {# Navigation #}
    <button class="swiper-button-prev" aria-label="الشريحة السابقة"></button>
    <button class="swiper-button-next" aria-label="الشريحة التالية"></button>
    <div class="swiper-pagination !bottom-6"></div>
  </div>

  {# Scroll Indicator #}
  <div class="absolute bottom-8 start-1/2 -translate-x-1/2 z-10 hidden md:block animate-bounce" aria-hidden="true">
    <div class="w-6 h-10 rounded-full border-2 border-white/40 flex items-start justify-center p-1.5">
      <div class="w-1.5 h-3 rounded-full bg-white/70"></div>
    </div>
  </div>
</section>
