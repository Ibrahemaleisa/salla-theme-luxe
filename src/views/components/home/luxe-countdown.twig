{# Luxe Countdown Component #}
{% set title = component.fields.title | default('عرض اليوم') %}
{% set subtitle = component.fields.subtitle | default('لا تفوت هذا العرض الحصري') %}
{% set end_date = component.fields.end_date %}
{% set bg_image = component.fields.bg_image %}
{% set bg_color = component.fields.bg_color | default('#1a1a2e') %}

<section class="section relative overflow-hidden" style="background-color: {{ bg_color }};">
  {# Background Image #}
  {% if bg_image %}
  <div class="absolute inset-0">
    <img src="{{ bg_image }}" alt="" class="w-full h-full object-cover" loading="lazy" aria-hidden="true">
    <div class="absolute inset-0 bg-black/60"></div>
  </div>
  {% endif %}

  {# Decorative circles #}
  <div class="absolute top-0 start-0 w-72 h-72 rounded-full bg-white/5 -translate-x-1/2 -translate-y-1/2" aria-hidden="true"></div>
  <div class="absolute bottom-0 end-0 w-48 h-48 rounded-full bg-white/5 translate-x-1/3 translate-y-1/3" aria-hidden="true"></div>

  <div class="container mx-auto px-4 relative">
    <div class="text-center text-white" data-animate>

      {# Section Header #}
      <p class="text-[var(--color-secondary)] font-bold uppercase tracking-widest text-sm mb-3">{{ subtitle }}</p>
      <h2 class="text-3xl md:text-4xl font-black mb-10">{{ title }}</h2>

      {# Countdown Timer #}
      {% if end_date %}
      <div
        class="inline-flex items-center gap-4 md:gap-8 mb-12"
        data-countdown="{{ end_date }}"
        aria-label="العد التنازلي للعرض"
      >
        {% set units = [
          { key: 'days', label: 'يوم' },
          { key: 'hours', label: 'ساعة' },
          { key: 'minutes', label: 'دقيقة' },
          { key: 'seconds', label: 'ثانية' }
        ] %}
        {% for unit in units %}
        <div class="flex flex-col items-center">
          <div class="w-16 h-16 md:w-20 md:h-20 bg-white/15 backdrop-blur-sm rounded-[var(--border-radius-card)] flex items-center justify-center border border-white/20">
            <span
              data-countdown-{{ unit.key }}
              class="text-2xl md:text-3xl font-black tabular-nums"
            >00</span>
          </div>
          <span class="text-xs text-white/60 mt-2">{{ unit.label }}</span>
        </div>
        {% if not loop.last %}
        <span class="text-2xl font-black text-[var(--color-secondary)] -mt-4" aria-hidden="true">:</span>
        {% endif %}
        {% endfor %}
      </div>
      {% endif %}

      {# Featured Products in Offer #}
      {% if store.offers %}
      <div class="swiper max-w-5xl mx-auto" data-swiper="products" data-per-view="4">
        <div class="swiper-wrapper pb-10">
          {% for product in store.offers | slice(0, 8) %}
          <div class="swiper-slide">
            {% include 'components/partials/product-card' with { product: product } %}
          </div>
          {% endfor %}
        </div>
        <button class="swiper-button-prev" aria-label="السابق"></button>
        <button class="swiper-button-next" aria-label="التالي"></button>
        <div class="swiper-pagination"></div>
      </div>
      {% endif %}

      <a href="{{ store.offers_url }}" class="btn-secondary btn btn-lg mt-8 inline-flex">
        عرض كل العروض
      </a>
    </div>
  </div>
</section>
