{# Main Header #}
{% set header_style = theme.settings.get('header_style') | default('default') %}
{% set is_sticky = theme.settings.get('header_sticky') %}
{% set is_transparent = theme.settings.get('header_transparent') %}

<header
  id="site-header"
  data-sticky="{{ is_sticky ? 'true' : 'false' }}"
  data-transparent="{{ is_transparent ? 'true' : 'false' }}"
  class="
    w-full z-[var(--z-header)] bg-white/95 dark:bg-[var(--color-surface)]/95 backdrop-blur-md border-b border-[var(--color-border)] transition-all duration-300
    {% if is_sticky %}sticky top-0{% endif %}
    {% if is_transparent %}is-transparent{% endif %}
    [&.is-scrolled]:shadow-md
    [&.is-hidden]:-translate-y-full
    {% if header_style == 'centered' %}text-center{% endif %}
  "
  style="height: var(--header-height);"
>
  <div class="container mx-auto px-4 h-full">
    <div class="flex items-center justify-between h-full gap-4">

      {# Mobile Menu Toggle #}
      <button
        data-mobile-menu-toggle
        class="lg:hidden flex flex-col gap-1.5 w-8 h-8 items-center justify-center"
        aria-label="القائمة الرئيسية"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="w-6 h-0.5 bg-current transition-all duration-300"></span>
        <span class="w-6 h-0.5 bg-current transition-all duration-300"></span>
        <span class="w-4 h-0.5 bg-current transition-all duration-300"></span>
      </button>

      {# Logo #}
      <a
        href="{{ store.url }}"
        class="flex-shrink-0 {{ header_style == 'centered' ? 'order-2 lg:order-none' : '' }}"
        aria-label="{{ store.name }}"
      >
        {% if theme.settings.get('logo') %}
          <img
            src="{{ theme.settings.get('logo') }}"
            alt="{{ store.name }}"
            class="h-10 w-auto object-contain"
            width="160"
            height="40"
            loading="eager"
          >
        {% else %}
          <span class="text-2xl font-black text-[var(--color-primary)] dark:text-white tracking-tight">
            {{ store.name }}
          </span>
        {% endif %}
      </a>

      {# Desktop Navigation #}
      {% if header_style != 'minimal' %}
      <nav class="hidden lg:flex items-center gap-1 flex-1 justify-center" aria-label="التنقل الرئيسي">
        {% for item in store.menu %}
        <div class="relative group">
          <a
            href="{{ item.url }}"
            class="px-3 py-2 text-sm font-medium hover:text-[var(--color-primary)] dark:hover:text-[var(--color-secondary)] transition-colors flex items-center gap-1 rounded-[var(--border-radius)]"
            {% if item.children %}aria-haspopup="true" aria-expanded="false"{% endif %}
          >
            {{ item.name }}
            {% if item.children %}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
            {% endif %}
          </a>

          {# Dropdown #}
          {% if item.children %}
          <div class="absolute top-full start-0 mt-2 min-w-[200px] bg-white dark:bg-[var(--color-surface)] rounded-[var(--border-radius-card)] shadow-lg border border-[var(--color-border)] py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-1 group-hover:translate-y-0 z-[var(--z-dropdown)]">
            {% for child in item.children %}
            <a
              href="{{ child.url }}"
              class="block px-4 py-2.5 text-sm hover:bg-gray-50 dark:hover:bg-gray-700 hover:text-[var(--color-primary)] transition-colors"
            >
              {{ child.name }}
            </a>
            {% endfor %}
          </div>
          {% endif %}
        </div>
        {% endfor %}
      </nav>
      {% endif %}

      {# Header Actions #}
      <div class="flex items-center gap-2">

        {# Search Toggle #}
        <button
          data-search-toggle
          class="w-9 h-9 flex items-center justify-center rounded-[var(--border-radius)] hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
          aria-label="بحث"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
        </button>

        {# Dark Mode Toggle #}
        <button
          data-dark-toggle
          class="hidden md:flex w-9 h-9 items-center justify-center rounded-[var(--border-radius)] hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
          aria-label="الوضع المظلم"
        >
          <svg data-dark-icon xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
          </svg>
          <svg data-light-icon xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
        </button>

        {# Wishlist #}
        <a
          href="{{ store.customer.wishlist_url | default('/wishlist') }}"
          class="hidden md:flex w-9 h-9 items-center justify-center rounded-[var(--border-radius)] hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors relative"
          aria-label="المفضلة"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
          </svg>
        </a>

        {# Customer Account #}
        {% if store.customer.is_logged_in %}
        <div class="relative group hidden md:block">
          <button
            class="w-9 h-9 flex items-center justify-center rounded-[var(--border-radius)] hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
            aria-label="حسابي"
          >
            {% if store.customer.avatar %}
              <img src="{{ store.customer.avatar }}" alt="{{ store.customer.name }}" class="w-7 h-7 rounded-full object-cover">
            {% else %}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            {% endif %}
          </button>
          <div class="absolute top-full end-0 mt-2 min-w-[180px] bg-white dark:bg-[var(--color-surface)] rounded-[var(--border-radius-card)] shadow-lg border border-[var(--color-border)] py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-[var(--z-dropdown)]">
            <div class="px-4 py-2 border-b border-[var(--color-border)] mb-1">
              <p class="text-xs font-semibold text-[var(--color-primary)] dark:text-white truncate">{{ store.customer.name }}</p>
              <p class="text-xs text-[var(--color-muted)] truncate">{{ store.customer.email }}</p>
            </div>
            <a href="{{ store.customer.profile_url }}" class="flex items-center gap-2 px-4 py-2 text-sm hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              ملفي الشخصي
            </a>
            <a href="{{ store.customer.orders_url }}" class="flex items-center gap-2 px-4 py-2 text-sm hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
              طلباتي
            </a>
            <a href="{{ store.customer.wishlist_url }}" class="flex items-center gap-2 px-4 py-2 text-sm hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
              المفضلة
            </a>
            <div class="border-t border-[var(--color-border)] mt-1 pt-1">
              <a href="{{ store.customer.logout_url }}" class="flex items-center gap-2 px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                تسجيل الخروج
              </a>
            </div>
          </div>
        </div>
        {% else %}
        <a
          href="{{ store.customer.login_url }}"
          class="hidden md:flex w-9 h-9 items-center justify-center rounded-[var(--border-radius)] hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
          aria-label="تسجيل الدخول"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
        </a>
        {% endif %}

        {# Cart Button #}
        <button
          data-cart-toggle
          class="relative w-9 h-9 flex items-center justify-center rounded-[var(--border-radius)] hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
          aria-label="سلة التسوق"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
          </svg>
          {% if store.cart.count > 0 %}
          <span
            class="absolute -top-1 -end-1 w-5 h-5 flex items-center justify-center bg-[var(--color-secondary)] text-[var(--color-primary)] text-[10px] font-black rounded-full"
            x-text="$store.cart.count || '{{ store.cart.count }}'"
          >{{ store.cart.count }}</span>
          {% endif %}
        </button>

      </div>
    </div>
  </div>
</header>
