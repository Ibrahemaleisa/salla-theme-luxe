{# Topbar #}
<div class="bg-[var(--color-primary)] text-white text-xs py-2 z-[var(--z-topbar)] relative" style="height: var(--topbar-height);">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between h-full">

      {# Social Links #}
      <div class="hidden md:flex items-center gap-3">
        {% if store.social.twitter %}
        <a href="{{ store.social.twitter }}" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-secondary)] transition-colors" aria-label="تويتر">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        {% endif %}
        {% if store.social.instagram %}
        <a href="{{ store.social.instagram }}" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-secondary)] transition-colors" aria-label="انستقرام">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        {% endif %}
        {% if store.social.snapchat %}
        <a href="{{ store.social.snapchat }}" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-secondary)] transition-colors" aria-label="سناب شات">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12.017 24c6.624 0 11.99-5.373 11.99-12.013 0-6.628-5.366-11.987-11.99-11.987z"/></svg>
        </a>
        {% endif %}
      </div>

      {# Announcement Text #}
      <p class="text-center text-xs font-medium flex-1 truncate px-2">
        {{ theme.settings.get('topbar_text') }}
      </p>

      {# Currency & Language #}
      <div class="hidden md:flex items-center gap-4 text-xs">
        {% if store.currencies | length > 1 %}
        <div class="relative" x-data="{ open: false }">
          <button @click="open = !open" class="flex items-center gap-1 hover:text-[var(--color-secondary)] transition-colors">
            {{ store.currency }}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div x-show="open" @click.away="open = false" class="absolute top-full start-0 mt-1 bg-white text-gray-800 rounded shadow-lg py-1 min-w-[100px] z-50">
            {% for currency in store.currencies %}
            <a href="{{ currency.url }}" class="block px-3 py-1.5 hover:bg-gray-100 text-xs">{{ currency.code }}</a>
            {% endfor %}
          </div>
        </div>
        {% endif %}
      </div>

    </div>
  </div>
</div>
