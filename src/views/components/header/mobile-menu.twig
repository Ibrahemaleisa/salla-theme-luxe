{# Mobile Navigation Menu #}
<nav
  id="mobile-menu"
  data-mobile-menu
  class="drawer drawer--closed lg:hidden"
  aria-label="القائمة الرئيسية للجوال"
  aria-hidden="true"
>
  {# Header #}
  <div class="drawer__header">
    <a href="{{ store.url }}" class="flex items-center gap-2">
      {% if theme.settings.get('logo') %}
        <img src="{{ theme.settings.get('logo') }}" alt="{{ store.name }}" class="h-8 w-auto">
      {% else %}
        <span class="font-black text-lg text-[var(--color-primary)] dark:text-white">{{ store.name }}</span>
      {% endif %}
    </a>
    <button data-mobile-menu-close class="btn-ghost btn-icon" aria-label="إغلاق القائمة">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  {# Customer Section #}
  <div class="px-4 py-3 bg-gray-50 dark:bg-gray-800/50 border-b border-[var(--color-border)]">
    {% if store.customer.is_logged_in %}
    <div class="flex items-center gap-3">
      {% if store.customer.avatar %}
        <img src="{{ store.customer.avatar }}" alt="{{ store.customer.name }}" class="w-10 h-10 rounded-full object-cover">
      {% else %}
        <div class="w-10 h-10 rounded-full bg-[var(--color-primary)] flex items-center justify-center text-white font-bold">
          {{ store.customer.name | first | upper }}
        </div>
      {% endif %}
      <div>
        <p class="font-semibold text-sm text-[var(--color-primary)] dark:text-white">{{ store.customer.name }}</p>
        <a href="{{ store.customer.profile_url }}" class="text-xs text-[var(--color-muted)] hover:text-[var(--color-primary)]">عرض الملف الشخصي</a>
      </div>
    </div>
    {% else %}
    <div class="flex items-center gap-3">
      <a href="{{ store.customer.login_url }}" class="btn-primary btn flex-1 text-center">تسجيل الدخول</a>
      <a href="{{ store.customer.register_url }}" class="btn-outline btn flex-1 text-center">إنشاء حساب</a>
    </div>
    {% endif %}
  </div>

  {# Navigation Body #}
  <div class="drawer__body scrollbar-thin">
    <ul class="space-y-0.5">
      {# Home #}
      <li>
        <a href="{{ store.url }}" class="flex items-center gap-3 px-4 py-3 rounded-[var(--border-radius)] hover:bg-gray-50 dark:hover:bg-gray-700 font-medium transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--color-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
          الرئيسية
        </a>
      </li>

      {# Dynamic Menu Items #}
      {% for item in store.menu %}
      <li>
        {% if item.children %}
        <button
          data-submenu-toggle
          class="w-full flex items-center justify-between gap-3 px-4 py-3 rounded-[var(--border-radius)] hover:bg-gray-50 dark:hover:bg-gray-700 font-medium transition-colors"
        >
          <span>{{ item.name }}</span>
          <svg data-chevron xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[var(--color-muted)] transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <ul class="hidden ps-4 mt-0.5 space-y-0.5 border-s-2 border-[var(--color-border)] ms-6">
          {% for child in item.children %}
          <li>
            <a href="{{ child.url }}" class="block px-4 py-2.5 text-sm rounded-[var(--border-radius)] hover:bg-gray-50 dark:hover:bg-gray-700 hover:text-[var(--color-primary)] transition-colors">
              {{ child.name }}
            </a>
          </li>
          {% endfor %}
        </ul>
        {% else %}
        <a
          href="{{ item.url }}"
          class="flex items-center gap-3 px-4 py-3 rounded-[var(--border-radius)] hover:bg-gray-50 dark:hover:bg-gray-700 font-medium transition-colors"
        >{{ item.name }}</a>
        {% endif %}
      </li>
      {% endfor %}

      {# Quick Links #}
      <li class="border-t border-[var(--color-border)] pt-2 mt-2">
        <a href="{{ store.customer.wishlist_url | default('/wishlist') }}" class="flex items-center gap-3 px-4 py-3 rounded-[var(--border-radius)] hover:bg-gray-50 dark:hover:bg-gray-700 font-medium transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--color-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
          </svg>
          المفضلة
        </a>
      </li>
      {% if store.customer.is_logged_in %}
      <li>
        <a href="{{ store.customer.orders_url }}" class="flex items-center gap-3 px-4 py-3 rounded-[var(--border-radius)] hover:bg-gray-50 dark:hover:bg-gray-700 font-medium transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--color-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
          </svg>
          طلباتي
        </a>
      </li>
      <li>
        <a href="{{ store.customer.logout_url }}" class="flex items-center gap-3 px-4 py-3 rounded-[var(--border-radius)] hover:bg-red-50 dark:hover:bg-red-900/20 text-red-600 font-medium transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
          </svg>
          تسجيل الخروج
        </a>
      </li>
      {% endif %}
    </ul>
  </div>

  {# Social Links #}
  <div class="drawer__footer">
    <div class="flex items-center justify-center gap-4">
      {% if store.social.instagram %}
      <a href="{{ store.social.instagram }}" target="_blank" rel="noopener noreferrer" class="text-[var(--color-muted)] hover:text-[var(--color-primary)] transition-colors" aria-label="انستقرام">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
      </a>
      {% endif %}
      {% if store.social.twitter %}
      <a href="{{ store.social.twitter }}" target="_blank" rel="noopener noreferrer" class="text-[var(--color-muted)] hover:text-[var(--color-primary)] transition-colors" aria-label="تويتر">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      {% endif %}
      {% if store.social.snapchat %}
      <a href="{{ store.social.snapchat }}" target="_blank" rel="noopener noreferrer" class="text-[var(--color-muted)] hover:text-[var(--color-primary)] transition-colors" aria-label="سناب شات">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12.017 24c6.624 0 11.99-5.373 11.99-12.013 0-6.628-5.366-11.987-11.99-11.987z"/></svg>
      </a>
      {% endif %}
      {% if store.social.tiktok %}
      <a href="{{ store.social.tiktok }}" target="_blank" rel="noopener noreferrer" class="text-[var(--color-muted)] hover:text-[var(--color-primary)] transition-colors" aria-label="تيك توك">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
      </a>
      {% endif %}
    </div>
  </div>
</nav>
