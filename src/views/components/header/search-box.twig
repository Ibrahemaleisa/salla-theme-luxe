{# Search Overlay #}
<div
  data-search-box
  class="hidden fixed inset-0 bg-black/70 backdrop-blur-sm z-[var(--z-modal)] p-4 md:p-8 animate-fade-in"
  role="dialog"
  aria-label="البحث"
  aria-modal="true"
>
  <div class="max-w-2xl mx-auto">
    <div class="bg-white dark:bg-[var(--color-surface)] rounded-2xl shadow-2xl overflow-hidden">
      {# Search Form #}
      <form action="{{ store.search_url }}" method="GET" class="relative">
        <div class="flex items-center px-4 border-b border-[var(--color-border)]">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--color-muted)] flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <input
            type="search"
            name="q"
            placeholder="ابحث عن منتجات، تصنيفات، علامات تجارية..."
            class="flex-1 px-4 py-5 text-base bg-transparent outline-none placeholder:text-[var(--color-muted)]"
            autocomplete="off"
            aria-label="البحث"
          >
          <button
            type="button"
            data-search-close
            class="flex-shrink-0 p-2 text-[var(--color-muted)] hover:text-[var(--color-primary)] transition-colors"
            aria-label="إغلاق البحث"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </form>

      {# Quick Links #}
      <div class="p-4">
        <p class="text-xs font-semibold text-[var(--color-muted)] uppercase tracking-wider mb-3">البحث السريع</p>
        <div class="flex flex-wrap gap-2">
          {% if store.categories %}
          {% for category in store.categories | slice(0, 6) %}
          <a
            href="{{ category.url }}"
            class="px-3 py-1.5 text-sm bg-gray-100 dark:bg-gray-700 rounded-full hover:bg-[var(--color-primary)] hover:text-white transition-all duration-200"
          >
            {{ category.name }}
          </a>
          {% endfor %}
          {% endif %}
        </div>
      </div>
    </div>

    <p class="text-center text-xs text-white/60 mt-4">اضغط <kbd class="bg-white/20 px-1.5 py-0.5 rounded text-white">Esc</kbd> للإغلاق</p>
  </div>
</div>
