{# Main Footer #}
<footer class="bg-gray-900 dark:bg-gray-950 text-gray-300 pt-16 pb-0">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 pb-12 border-b border-gray-800">

      {# Brand Column #}
      <div class="lg:col-span-1">
        <a href="{{ store.url }}" class="inline-block mb-5" aria-label="{{ store.name }}">
          {% if theme.settings.get('logo') %}
            <img src="{{ theme.settings.get('logo') }}" alt="{{ store.name }}" class="h-10 w-auto brightness-0 invert">
          {% else %}
            <span class="text-2xl font-black text-white">{{ store.name }}</span>
          {% endif %}
        </a>
        <p class="text-sm leading-relaxed text-gray-400 mb-6">{{ store.description | truncate(120) }}</p>

        {# Contact Info #}
        <div class="space-y-3">
          {% if store.phone %}
          <a href="tel:{{ store.phone }}" class="flex items-center gap-3 text-sm hover:text-white transition-colors group">
            <span class="w-8 h-8 rounded-full bg-gray-800 group-hover:bg-[var(--color-primary)] flex items-center justify-center transition-colors flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </span>
            {{ store.phone }}
          </a>
          {% endif %}
          {% if store.email %}
          <a href="mailto:{{ store.email }}" class="flex items-center gap-3 text-sm hover:text-white transition-colors group">
            <span class="w-8 h-8 rounded-full bg-gray-800 group-hover:bg-[var(--color-primary)] flex items-center justify-center transition-colors flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </span>
            {{ store.email }}
          </a>
          {% endif %}
        </div>
      </div>

      {# Quick Links #}
      <div>
        <h3 class="text-white font-bold mb-5 text-base">روابط سريعة</h3>
        <ul class="space-y-3">
          <li><a href="{{ store.url }}" class="text-sm hover:text-white hover:translate-x-1 rtl:hover:-translate-x-1 inline-flex transition-all duration-200">الرئيسية</a></li>
          <li><a href="{{ store.products_url }}" class="text-sm hover:text-white hover:translate-x-1 rtl:hover:-translate-x-1 inline-flex transition-all duration-200">المنتجات</a></li>
          <li><a href="{{ store.offers_url }}" class="text-sm hover:text-white hover:translate-x-1 rtl:hover:-translate-x-1 inline-flex transition-all duration-200">العروض</a></li>
          <li><a href="{{ store.brands_url }}" class="text-sm hover:text-white hover:translate-x-1 rtl:hover:-translate-x-1 inline-flex transition-all duration-200">العلامات التجارية</a></li>
          <li><a href="{{ store.blog_url }}" class="text-sm hover:text-white hover:translate-x-1 rtl:hover:-translate-x-1 inline-flex transition-all duration-200">المدونة</a></li>
        </ul>
      </div>

      {# Customer Service #}
      <div>
        <h3 class="text-white font-bold mb-5 text-base">خدمة العملاء</h3>
        <ul class="space-y-3">
          <li><a href="{{ store.customer.profile_url }}" class="text-sm hover:text-white hover:translate-x-1 rtl:hover:-translate-x-1 inline-flex transition-all duration-200">حسابي</a></li>
          <li><a href="{{ store.customer.orders_url }}" class="text-sm hover:text-white hover:translate-x-1 rtl:hover:-translate-x-1 inline-flex transition-all duration-200">طلباتي</a></li>
          <li><a href="{{ store.customer.wishlist_url }}" class="text-sm hover:text-white hover:translate-x-1 rtl:hover:-translate-x-1 inline-flex transition-all duration-200">المفضلة</a></li>
          <li><a href="/contact" class="text-sm hover:text-white hover:translate-x-1 rtl:hover:-translate-x-1 inline-flex transition-all duration-200">تواصل معنا</a></li>
          <li><a href="/faq" class="text-sm hover:text-white hover:translate-x-1 rtl:hover:-translate-x-1 inline-flex transition-all duration-200">الأسئلة الشائعة</a></li>
        </ul>
      </div>

      {# Pages & Social #}
      <div>
        <h3 class="text-white font-bold mb-5 text-base">معلومات</h3>
        <ul class="space-y-3 mb-8">
          {% if store.pages %}
          {% for page in store.pages | slice(0, 5) %}
          <li><a href="{{ page.url }}" class="text-sm hover:text-white hover:translate-x-1 rtl:hover:-translate-x-1 inline-flex transition-all duration-200">{{ page.title }}</a></li>
          {% endfor %}
          {% else %}
          <li><a href="/about" class="text-sm hover:text-white inline-flex transition-all duration-200">من نحن</a></li>
          <li><a href="/privacy" class="text-sm hover:text-white inline-flex transition-all duration-200">سياسة الخصوصية</a></li>
          <li><a href="/terms" class="text-sm hover:text-white inline-flex transition-all duration-200">الشروط والأحكام</a></li>
          <li><a href="/returns" class="text-sm hover:text-white inline-flex transition-all duration-200">سياسة الإرجاع</a></li>
          {% endif %}
        </ul>

        {# Social Media #}
        <h3 class="text-white font-bold mb-4 text-sm">تابعنا</h3>
        <div class="flex items-center gap-3">
          {% if store.social.instagram %}
          <a href="{{ store.social.instagram }}" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-gray-800 hover:bg-gradient-to-br hover:from-purple-600 hover:to-pink-500 flex items-center justify-center text-gray-400 hover:text-white transition-all duration-200" aria-label="انستقرام">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          {% endif %}
          {% if store.social.twitter %}
          <a href="{{ store.social.twitter }}" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-gray-800 hover:bg-black flex items-center justify-center text-gray-400 hover:text-white transition-all duration-200" aria-label="تويتر">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          {% endif %}
          {% if store.social.snapchat %}
          <a href="{{ store.social.snapchat }}" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-gray-800 hover:bg-yellow-400 flex items-center justify-center text-gray-400 hover:text-gray-900 transition-all duration-200" aria-label="سناب شات">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12.017 24c6.624 0 11.99-5.373 11.99-12.013 0-6.628-5.366-11.987-11.99-11.987z"/></svg>
          </a>
          {% endif %}
          {% if store.social.tiktok %}
          <a href="{{ store.social.tiktok }}" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-gray-800 hover:bg-[#ff0050] flex items-center justify-center text-gray-400 hover:text-white transition-all duration-200" aria-label="تيك توك">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
          </a>
          {% endif %}
        </div>
      </div>
    </div>

    {# Payment Methods #}
    <div class="py-6 border-b border-gray-800">
      <div class="flex flex-wrap items-center justify-center gap-3">
        {% for payment in store.payment_methods %}
        {% if payment.icon %}
        <img src="{{ payment.icon }}" alt="{{ payment.name }}" class="h-7 w-auto object-contain opacity-60 hover:opacity-100 transition-opacity grayscale hover:grayscale-0" loading="lazy">
        {% endif %}
        {% endfor %}
      </div>
    </div>

    {# Copyright #}
    <div class="py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-gray-500">
      <p>
        © {{ "now" | date("Y") }} {{ store.name }}. جميع الحقوق محفوظة.
      </p>
      <div class="flex items-center gap-1">
        <span>مدعوم بـ</span>
        <a href="https://salla.sa" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors font-semibold">سلة</a>
      </div>
    </div>
  </div>
</footer>
