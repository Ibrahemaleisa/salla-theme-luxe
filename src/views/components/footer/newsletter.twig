{# Newsletter Section #}
<section class="bg-[var(--color-primary)] py-16 relative overflow-hidden">
  {# Decorative elements #}
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-0 start-0 w-64 h-64 rounded-full bg-[var(--color-secondary)] -translate-x-1/2 -translate-y-1/2"></div>
    <div class="absolute bottom-0 end-0 w-48 h-48 rounded-full bg-[var(--color-secondary)] translate-x-1/3 translate-y-1/3"></div>
  </div>

  <div class="container mx-auto px-4 relative">
    <div class="max-w-2xl mx-auto text-center">
      <span class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-[var(--color-secondary)]/20 mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-[var(--color-secondary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      </span>
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">
        اشترك في نشرتنا البريدية
      </h2>
      <p class="text-white/70 mb-8">
        احصل على أحدث العروض والمنتجات مباشرة في بريدك
      </p>

      <form action="{{ store.newsletter_url }}" method="POST" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input type="hidden" name="_token" value="{{ csrf_token }}">
        <input
          type="email"
          name="email"
          placeholder="بريدك الإلكتروني"
          required
          class="form-control flex-1 py-3.5 bg-white/10 border-white/20 text-white placeholder:text-white/50 focus:border-[var(--color-secondary)] focus:ring-[var(--color-secondary)]"
        >
        <button
          type="submit"
          class="btn-secondary btn btn-lg whitespace-nowrap"
        >
          اشترك الآن
        </button>
      </form>

      <p class="text-white/40 text-xs mt-4">بالاشتراك، أنت توافق على <a href="/privacy" class="underline hover:text-white/60">سياسة الخصوصية</a></p>
    </div>
  </div>
</section>
