{# Product Filters Sidebar #}
<form data-filter-form action="{{ current_url }}" method="GET">

  {# Active Filters #}
  {% if request.filters %}
  <div class="mb-6">
    <div class="flex items-center justify-between mb-3">
      <h3 class="text-sm font-bold">الفلاتر المطبقة</h3>
      <a href="{{ current_url }}" class="text-xs text-red-500 hover:underline">مسح الكل</a>
    </div>
    <div class="flex flex-wrap gap-2">
      {% for filter in request.filters %}
      <a href="{{ filter.remove_url }}" class="inline-flex items-center gap-1 bg-gray-100 dark:bg-gray-700 text-xs px-2.5 py-1 rounded-full hover:bg-red-50 hover:text-red-600 transition-colors">
        {{ filter.label }}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </a>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {# Price Range #}
  <div class="mb-6 pb-6 border-b border-[var(--color-border)]">
    <h3 class="text-sm font-bold mb-4">نطاق السعر</h3>
    <div class="relative">
      <div class="relative h-1.5 bg-gray-200 dark:bg-gray-600 rounded-full mb-4">
        <div data-price-track class="absolute h-full bg-[var(--color-primary)] rounded-full"></div>
      </div>
      <div class="flex items-center gap-3">
        <div class="flex-1">
          <label for="price-min" class="sr-only">الحد الأدنى للسعر</label>
          <input
            id="price-min"
            data-price-min
            type="range"
            name="price_min"
            min="0"
            max="{{ request.price_max | default(10000) }}"
            value="{{ request.price_min | default(0) }}"
            class="w-full accent-[var(--color-primary)]"
          >
        </div>
        <div class="flex-1">
          <label for="price-max" class="sr-only">الحد الأقصى للسعر</label>
          <input
            id="price-max"
            data-price-max
            type="range"
            name="price_max"
            min="0"
            max="{{ request.price_max | default(10000) }}"
            value="{{ request.price_max | default(10000) }}"
            class="w-full accent-[var(--color-primary)]"
          >
        </div>
      </div>
      <div class="flex items-center justify-between text-xs text-[var(--color-muted)] mt-1">
        <span>{{ request.price_min | default(0) }} {{ store.currency }}</span>
        <span>{{ request.price_max | default(10000) }} {{ store.currency }}</span>
      </div>
    </div>
  </div>

  {# Categories #}
  {% if store.categories %}
  <div class="mb-6 pb-6 border-b border-[var(--color-border)]" x-data="{ open: true }">
    <button
      type="button"
      @click="open = !open"
      class="w-full flex items-center justify-between text-sm font-bold mb-3"
    >
      التصنيفات
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform duration-200" :class="open ? 'rotate-180' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </button>
    <div x-show="open" x-transition class="space-y-2">
      {% for cat in store.categories | slice(0, 10) %}
      <label class="flex items-center gap-3 cursor-pointer group">
        <input
          type="checkbox"
          name="category[]"
          value="{{ cat.id }}"
          {{ request.category and cat.id in request.category ? 'checked' : '' }}
          class="w-4 h-4 rounded border-[var(--color-border)] accent-[var(--color-primary)] cursor-pointer"
        >
        <span class="text-sm group-hover:text-[var(--color-primary)] transition-colors flex-1">{{ cat.name }}</span>
        {% if cat.products_count %}
        <span class="text-xs text-[var(--color-muted)]">{{ cat.products_count }}</span>
        {% endif %}
      </label>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {# Brands #}
  {% if store.brands %}
  <div class="mb-6 pb-6 border-b border-[var(--color-border)]" x-data="{ open: true }">
    <button
      type="button"
      @click="open = !open"
      class="w-full flex items-center justify-between text-sm font-bold mb-3"
    >
      العلامات التجارية
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform duration-200" :class="open ? 'rotate-180' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </button>
    <div x-show="open" x-transition class="space-y-2 max-h-48 overflow-y-auto scrollbar-thin">
      {% for brand in store.brands %}
      <label class="flex items-center gap-3 cursor-pointer group">
        <input
          type="checkbox"
          name="brand[]"
          value="{{ brand.id }}"
          {{ request.brand and brand.id in request.brand ? 'checked' : '' }}
          class="w-4 h-4 rounded border-[var(--color-border)] accent-[var(--color-primary)] cursor-pointer"
        >
        <span class="text-sm group-hover:text-[var(--color-primary)] transition-colors">{{ brand.name }}</span>
      </label>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {# Availability #}
  <div class="mb-6">
    <h3 class="text-sm font-bold mb-3">التوفر</h3>
    <div class="space-y-2">
      <label class="flex items-center gap-3 cursor-pointer group">
        <input
          type="checkbox"
          name="in_stock"
          value="1"
          {{ request.in_stock ? 'checked' : '' }}
          class="w-4 h-4 rounded border-[var(--color-border)] accent-[var(--color-primary)] cursor-pointer"
        >
        <span class="text-sm group-hover:text-[var(--color-primary)] transition-colors">متوفر في المخزون</span>
      </label>
      <label class="flex items-center gap-3 cursor-pointer group">
        <input
          type="checkbox"
          name="on_sale"
          value="1"
          {{ request.on_sale ? 'checked' : '' }}
          class="w-4 h-4 rounded border-[var(--color-border)] accent-[var(--color-primary)] cursor-pointer"
        >
        <span class="text-sm group-hover:text-[var(--color-primary)] transition-colors">تخفيضات</span>
      </label>
    </div>
  </div>

  {# Submit #}
  <button type="submit" class="btn-primary btn btn-full">
    تطبيق الفلاتر
  </button>
</form>
