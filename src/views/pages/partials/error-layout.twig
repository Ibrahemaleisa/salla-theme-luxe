<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ error_title }} | {{ store.name }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ 'css/theme.css' | asset }}">
  <style>
    :root { --color-primary: #1a1a2e; --color-secondary: #e2b96f; }
    body { font-family: 'Tajawal', sans-serif; background: #f9fafb; color: #1f2937; min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2rem; text-align: center; direction: rtl; }
  </style>
</head>
<body>
  <div style="max-width: 500px; width: 100%;">
    <a href="{{ store.url }}" style="display: inline-block; margin-bottom: 2rem;">
      {% if theme.settings.get('logo') %}
      <img src="{{ theme.settings.get('logo') }}" alt="{{ store.name }}" style="height: 40px; width: auto;">
      {% else %}
      <span style="font-size: 1.5rem; font-weight: 900; color: var(--color-primary);">{{ store.name }}</span>
      {% endif %}
    </a>

    <div style="font-size: 8rem; font-weight: 900; color: var(--color-primary); opacity: 0.08; line-height: 1; margin-bottom: -1rem;">{{ error_code }}</div>

    <div style="margin-bottom: 2rem;">
      {{ block('icon') }}
    </div>

    <h1 style="font-size: 1.75rem; font-weight: 900; color: var(--color-primary); margin-bottom: 0.75rem;">{{ error_title }}</h1>
    <p style="color: #6b7280; margin-bottom: 2rem; line-height: 1.7;">{{ error_desc }}</p>

    <div style="display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;">
      <a href="{{ store.url }}" style="display: inline-flex; align-items: center; gap: 0.5rem; background: var(--color-primary); color: white; padding: 0.875rem 1.75rem; border-radius: 0.5rem; font-weight: 600; font-size: 0.875rem; text-decoration: none;">
        <svg xmlns="http://www.w3.org/2000/svg" style="width: 1rem; height: 1rem;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        العودة للرئيسية
      </a>
      <button onclick="history.back()" style="display: inline-flex; align-items: center; gap: 0.5rem; border: 2px solid #e5e7eb; color: #6b7280; padding: 0.875rem 1.75rem; border-radius: 0.5rem; font-weight: 600; font-size: 0.875rem; background: white; cursor: pointer;">
        الصفحة السابقة
      </button>
    </div>
  </div>
</body>
</html>
