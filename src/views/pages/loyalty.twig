{% extends "layouts.master" %}
{% set page_title = 'برنامج المكافآت' %}

{% block content %}
<div class="bg-gradient-primary text-white py-16">
  <div class="container mx-auto px-4 text-center">
    <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-[var(--color-secondary)]/20 mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[var(--color-secondary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
    </div>
    <h1 class="text-3xl md:text-4xl font-black mb-3">برنامج المكافآت</h1>
    <p class="text-white/70 max-w-lg mx-auto">اجمع نقاطك مع كل عملية شراء واستبدلها بخصومات رائعة</p>
    {% if store.customer.is_logged_in and loyalty %}
    <div class="inline-flex items-center gap-3 mt-6 bg-white/10 backdrop-blur-sm rounded-2xl px-6 py-3">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[var(--color-secondary)]" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
      <span class="text-2xl font-black">{{ loyalty.points }}</span>
      <span class="text-white/70">نقطة متاحة</span>
    </div>
    {% endif %}
  </div>
</div>

<section class="section">
  <div class="container mx-auto px-4">
    {% if store.customer.is_logged_in %}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      {# Points Summary #}
      <div class="lg:col-span-1 space-y-4">
        <div class="card-flat rounded-[var(--border-radius-card)] p-6">
          <h2 class="font-bold text-[var(--color-primary)] dark:text-white mb-5">ملخص النقاط</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center py-2 border-b border-[var(--color-border)]">
              <span class="text-sm text-[var(--color-muted)]">النقاط المتاحة</span>
              <span class="font-black text-lg text-[var(--color-primary)] dark:text-white">{{ loyalty.points | default(0) }}</span>
            </div>
            <div class="flex justify-between items-center py-2 border-b border-[var(--color-border)]">
              <span class="text-sm text-[var(--color-muted)]">مكافئ لـ</span>
              <span class="font-bold text-green-600">{{ loyalty.value.formatted | default('0 ر.س') }}</span>
            </div>
            <div class="flex justify-between items-center py-2">
              <span class="text-sm text-[var(--color-muted)]">مستوى العضوية</span>
              <span class="badge badge-primary">{{ loyalty.tier | default('فضي') }}</span>
            </div>
          </div>
          {% if loyalty.points > 0 %}
          <a href="{{ loyalty.redeem_url | default('#') }}" class="btn-primary btn btn-full mt-5">
            استبدال النقاط
          </a>
          {% endif %}
        </div>

        {# How it Works #}
        <div class="card-flat rounded-[var(--border-radius-card)] p-6">
          <h3 class="font-bold text-[var(--color-primary)] dark:text-white mb-4">كيف يعمل البرنامج؟</h3>
          <ol class="space-y-4">
            {% set steps = [
              { num: '1', title: 'تسوق وأكسب', desc: 'احصل على نقطة لكل ريال تنفقه' },
              { num: '2', title: 'اجمع نقاطك', desc: 'كلما تسوقت أكثر كلما حصلت على نقاط أكثر' },
              { num: '3', title: 'استبدل بخصومات', desc: 'استخدم نقاطك للحصول على خصومات على طلباتك القادمة' }
            ] %}
            {% for step in steps %}
            <li class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-full bg-[var(--color-primary)] text-white flex items-center justify-center text-xs font-black flex-shrink-0">{{ step.num }}</div>
              <div>
                <p class="font-semibold text-sm">{{ step.title }}</p>
                <p class="text-xs text-[var(--color-muted)] mt-0.5">{{ step.desc }}</p>
              </div>
            </li>
            {% endfor %}
          </ol>
        </div>
      </div>

      {# Points History #}
      <div class="lg:col-span-2">
        <div class="card-flat rounded-[var(--border-radius-card)] overflow-hidden">
          <div class="px-6 py-4 border-b border-[var(--color-border)]">
            <h2 class="font-bold text-[var(--color-primary)] dark:text-white">سجل النقاط</h2>
          </div>
          {% if loyalty.transactions %}
          <div class="divide-y divide-[var(--color-border)]">
            {% for transaction in loyalty.transactions %}
            <div class="flex items-center justify-between px-6 py-4">
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-full {{ transaction.type == 'earned' ? 'bg-green-100 text-green-600' : 'bg-orange-100 text-orange-600' }} flex items-center justify-center">
                  {% if transaction.type == 'earned' %}
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
                  {% else %}
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4"/></svg>
                  {% endif %}
                </div>
                <div>
                  <p class="text-sm font-semibold">{{ transaction.description }}</p>
                  <p class="text-xs text-[var(--color-muted)]">{{ transaction.date }}</p>
                </div>
              </div>
              <span class="font-bold {{ transaction.type == 'earned' ? 'text-green-600' : 'text-orange-600' }}">
                {{ transaction.type == 'earned' ? '+' : '-' }}{{ transaction.points }} نقطة
              </span>
            </div>
            {% endfor %}
          </div>
          {% else %}
          <div class="empty-state py-16">
            <svg xmlns="http://www.w3.org/2000/svg" class="empty-state__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            <h3 class="empty-state__title text-base">لا يوجد سجل بعد</h3>
            <p class="empty-state__desc text-sm">ابدأ بالتسوق لجمع نقاطك</p>
          </div>
          {% endif %}
        </div>
      </div>
    </div>

    {% else %}
    <div class="max-w-md mx-auto text-center py-16">
      <div class="w-20 h-20 rounded-2xl bg-[var(--color-primary)]/10 flex items-center justify-center mx-auto mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
      </div>
      <h2 class="text-xl font-black text-[var(--color-primary)] dark:text-white mb-3">سجل الدخول للوصول</h2>
      <p class="text-[var(--color-muted)] mb-6">سجّل دخولك للاستفادة من برنامج المكافآت وجمع نقاطك</p>
      <div class="flex flex-col gap-3">
        <a href="{{ store.customer.login_url }}" class="btn-primary btn btn-lg">تسجيل الدخول</a>
        <a href="{{ store.customer.register_url }}" class="btn-outline btn">إنشاء حساب جديد</a>
      </div>
    </div>
    {% endif %}
  </div>
</section>
{% endblock %}
