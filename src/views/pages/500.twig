{% extends "layouts.master" %}
{% set page_title = 'خطأ في الخادم - 500' %}

{% block content %}
<section class="min-h-[80vh] flex items-center justify-center section">
  <div class="container mx-auto px-4">
    <div class="max-w-lg mx-auto text-center">
      <div class="relative mb-8">
        <div class="text-[10rem] font-black text-red-500/10 leading-none select-none">500</div>
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="w-36 h-36 rounded-full bg-red-500/10 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 text-red-400/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
            </svg>
          </div>
        </div>
      </div>
      <h1 class="text-2xl md:text-3xl font-black text-[var(--color-primary)] dark:text-white mb-3">خطأ في الخادم</h1>
      <p class="text-[var(--color-muted)] mb-8 leading-relaxed">حدث خطأ غير متوقع في الخادم. نعمل على حل المشكلة في أقرب وقت. يرجى المحاولة مرة أخرى.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <button onclick="window.location.reload()" class="btn-primary btn btn-lg">إعادة المحاولة</button>
        <a href="{{ store.url }}" class="btn-outline btn btn-lg">العودة للرئيسية</a>
      </div>
    </div>
  </div>
</section>
{% endblock %}
