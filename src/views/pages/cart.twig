{% extends "layouts.master" %}

{% set page_title = 'سلة التسوق' %}
{% set page_description = 'مراجعة منتجاتك وإتمام عملية الشراء' %}

{% block content %}
<div class="bg-gray-50 dark:bg-gray-800/50 border-b border-[var(--color-border)]">
  <div class="container mx-auto px-4 py-6">
    {% if theme.settings.get('show_breadcrumb') %}
    <nav class="breadcrumb" aria-label="مسار التنقل">
      <div class="breadcrumb__item"><a href="{{ store.url }}" class="breadcrumb__link">الرئيسية</a></div>
      <div class="breadcrumb__item" aria-current="page">سلة التسوق</div>
    </nav>
    {% endif %}
    <h1 class="text-2xl md:text-3xl font-black text-[var(--color-primary)] dark:text-white mt-2">
      سلة التسوق
      {% if store.cart.count > 0 %}
      <span class="text-base font-normal text-[var(--color-muted)] ms-2">({{ store.cart.count }} منتج)</span>
      {% endif %}
    </h1>
  </div>
</div>

<section class="section">
  <div class="container mx-auto px-4">
    {% if store.cart.count > 0 %}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      {# Cart Items #}
      <div class="lg:col-span-2">
        <div class="card-flat rounded-[var(--border-radius-card)] overflow-hidden">
          {# Table Header #}
          <div class="hidden md:grid grid-cols-12 gap-4 px-6 py-4 bg-gray-50 dark:bg-gray-800 text-xs font-semibold text-[var(--color-muted)] uppercase tracking-wide border-b border-[var(--color-border)]">
            <div class="col-span-6">المنتج</div>
            <div class="col-span-2 text-center">السعر</div>
            <div class="col-span-2 text-center">الكمية</div>
            <div class="col-span-2 text-center">الإجمالي</div>
          </div>

          {# Cart Items List #}
          <div id="cart-items" class="divide-y divide-[var(--color-border)]">
            {% for item in store.cart.items %}
            <div class="grid grid-cols-12 gap-4 items-center p-4 md:px-6 md:py-5 group" data-cart-item="{{ item.id }}">

              {# Product #}
              <div class="col-span-12 md:col-span-6 flex items-center gap-4">
                <a href="{{ item.product.url }}" class="flex-shrink-0 w-20 h-20 rounded-[var(--border-radius)] overflow-hidden bg-gray-100 dark:bg-gray-700">
                  <img src="{{ item.product.thumbnail }}" alt="{{ item.product.name }}" class="w-full h-full object-cover" loading="lazy">
                </a>
                <div class="min-w-0">
                  <a href="{{ item.product.url }}" class="font-semibold text-sm leading-snug hover:text-[var(--color-primary)] transition-colors line-clamp-2">
                    {{ item.product.name }}
                  </a>
                  {% if item.options %}
                  <p class="text-xs text-[var(--color-muted)] mt-1">{{ item.options | join(' · ') }}</p>
                  {% endif %}
                  <button
                    class="text-xs text-red-500 hover:text-red-700 mt-2 flex items-center gap-1 transition-colors"
                    data-remove-cart-item="{{ item.id }}"
                    aria-label="حذف {{ item.product.name }}"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                    حذف
                  </button>
                </div>
              </div>

              {# Price #}
              <div class="col-span-4 md:col-span-2 text-center">
                <div class="md:hidden text-xs text-[var(--color-muted)] mb-1">السعر</div>
                <span class="font-semibold text-sm">{{ item.unit_price.formatted }}</span>
              </div>

              {# Quantity #}
              <div class="col-span-4 md:col-span-2 flex justify-center">
                <div class="flex items-center border border-[var(--color-border)] rounded-[var(--border-radius)] overflow-hidden" data-qty-control>
                  <button data-qty-dec class="w-8 h-8 flex items-center justify-center hover:bg-gray-50 dark:hover:bg-gray-700 text-sm font-bold transition-colors" aria-label="تقليل">−</button>
                  <input
                    data-qty-input
                    type="number"
                    value="{{ item.quantity }}"
                    min="1"
                    max="{{ item.product.quantity }}"
                    class="w-10 h-8 text-center text-sm border-x border-[var(--color-border)] bg-transparent outline-none"
                    aria-label="الكمية"
                    data-cart-item-qty="{{ item.id }}"
                  >
                  <button data-qty-inc class="w-8 h-8 flex items-center justify-center hover:bg-gray-50 dark:hover:bg-gray-700 text-sm font-bold transition-colors" aria-label="زيادة">+</button>
                </div>
              </div>

              {# Total #}
              <div class="col-span-4 md:col-span-2 text-center">
                <div class="md:hidden text-xs text-[var(--color-muted)] mb-1">الإجمالي</div>
                <span class="font-bold text-[var(--color-primary)] dark:text-white">{{ item.price.formatted }}</span>
              </div>
            </div>
            {% endfor %}
          </div>

          {# Cart Actions #}
          <div class="flex items-center justify-between gap-4 px-6 py-4 bg-gray-50 dark:bg-gray-800 border-t border-[var(--color-border)] flex-wrap">
            <a href="{{ store.products_url }}" class="btn-ghost btn-sm btn flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 rtl:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
              </svg>
              مواصلة التسوق
            </a>
            <button
              class="btn-outline btn-sm btn text-red-500 border-red-200 hover:bg-red-500 hover:text-white hover:border-red-500"
              data-clear-cart
            >
              إفراغ السلة
            </button>
          </div>
        </div>
      </div>

      {# Order Summary #}
      <div class="lg:col-span-1">
        <div class="card-flat rounded-[var(--border-radius-card)] p-6 sticky top-24">
          <h2 class="text-lg font-bold text-[var(--color-primary)] dark:text-white mb-5 pb-4 border-b border-[var(--color-border)]">
            ملخص الطلب
          </h2>

          <div class="space-y-3 mb-5">
            <div class="flex justify-between text-sm">
              <span class="text-[var(--color-muted)]">المجموع الجزئي ({{ store.cart.count }} منتج)</span>
              <span class="font-medium">{{ store.cart.subtotal.formatted }}</span>
            </div>
            {% if store.cart.discount.amount > 0 %}
            <div class="flex justify-between text-sm text-green-600">
              <span>الخصم</span>
              <span class="font-medium">− {{ store.cart.discount.formatted }}</span>
            </div>
            {% endif %}
            {% if store.cart.tax %}
            <div class="flex justify-between text-sm">
              <span class="text-[var(--color-muted)]">الضريبة</span>
              <span class="font-medium">{{ store.cart.tax.formatted }}</span>
            </div>
            {% endif %}
            <div class="flex justify-between text-sm">
              <span class="text-[var(--color-muted)]">الشحن</span>
              <span class="font-medium">{{ store.cart.shipping.formatted | default('يُحسب عند الدفع') }}</span>
            </div>
          </div>

          {# Coupon #}
          <div class="mb-5 pb-5 border-b border-[var(--color-border)]" x-data="{ open: false }">
            <button @click="open = !open" type="button" class="flex items-center gap-2 text-sm text-[var(--color-primary)] font-medium">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
              </svg>
              لديك كود خصم؟
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform" :class="open ? 'rotate-180' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div x-show="open" x-transition class="mt-3 flex gap-2">
              <input type="text" placeholder="أدخل الكود" class="form-control flex-1 py-2.5 text-sm">
              <button type="button" class="btn-primary btn-sm btn whitespace-nowrap">تطبيق</button>
            </div>
          </div>

          {# Total #}
          <div class="flex justify-between items-center mb-6">
            <span class="text-base font-bold">الإجمالي</span>
            <span class="text-2xl font-black text-[var(--color-primary)] dark:text-white">{{ store.cart.total.formatted }}</span>
          </div>

          {# Checkout Button #}
          <a href="{{ store.cart.checkout_url }}" class="btn-primary btn btn-full btn-lg mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
            إتمام الشراء بأمان
          </a>

          {# Payment Methods #}
          <div class="flex flex-wrap items-center justify-center gap-2 pt-4 border-t border-[var(--color-border)]">
            {% for payment in store.payment_methods | slice(0, 5) %}
            {% if payment.icon %}
            <img src="{{ payment.icon }}" alt="{{ payment.name }}" class="h-6 w-auto object-contain opacity-70" loading="lazy">
            {% endif %}
            {% endfor %}
          </div>

          {# Trust Signals #}
          <div class="grid grid-cols-3 gap-2 mt-4 pt-4 border-t border-[var(--color-border)]">
            <div class="flex flex-col items-center text-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
              </svg>
              <span class="text-xs text-[var(--color-muted)]">دفع آمن</span>
            </div>
            <div class="flex flex-col items-center text-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
              </svg>
              <span class="text-xs text-[var(--color-muted)]">توصيل سريع</span>
            </div>
            <div class="flex flex-col items-center text-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
              </svg>
              <span class="text-xs text-[var(--color-muted)]">إرجاع مجاني</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    {% else %}
    {# Empty Cart #}
    <div class="empty-state py-24">
      <svg xmlns="http://www.w3.org/2000/svg" class="empty-state__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
      </svg>
      <h2 class="empty-state__title">سلتك فارغة</h2>
      <p class="empty-state__desc">لم تضف أي منتجات إلى سلتك بعد. ابدأ التسوق الآن واكتشف أحدث المنتجات.</p>
      <a href="{{ store.products_url }}" class="btn-primary btn btn-lg">
        ابدأ التسوق
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 rtl:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
    {% endif %}
  </div>
</section>
{% endblock %}
