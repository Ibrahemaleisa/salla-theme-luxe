{% extends "layouts.master" %}
{% set page_title = 'طلباتي' %}

{% block content %}
<div class="bg-gray-50 dark:bg-gray-800/50 border-b border-[var(--color-border)]">
  <div class="container mx-auto px-4 py-6">
    <nav class="breadcrumb"><div class="breadcrumb__item"><a href="{{ store.url }}" class="breadcrumb__link">الرئيسية</a></div><div class="breadcrumb__item"><a href="{{ store.customer.profile_url }}" class="breadcrumb__link">حسابي</a></div><div class="breadcrumb__item" aria-current="page">طلباتي</div></nav>
    <h1 class="text-2xl md:text-3xl font-black text-[var(--color-primary)] dark:text-white mt-2">طلباتي</h1>
  </div>
</div>

<section class="section">
  <div class="container mx-auto px-4 max-w-4xl">
    {% if orders.items %}
    <div class="space-y-4">
      {% for order in orders.items %}
      <a href="{{ order.url }}" class="card-flat rounded-[var(--border-radius-card)] p-5 flex flex-col sm:flex-row sm:items-center justify-between gap-4 hover:border-[var(--color-primary)] transition-colors group block">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-[var(--border-radius)] bg-gray-100 dark:bg-gray-700 flex items-center justify-center flex-shrink-0 group-hover:bg-[var(--color-primary)] transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[var(--color-muted)] group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
          </div>
          <div>
            <p class="font-bold text-sm">طلب رقم #{{ order.reference_id }}</p>
            <p class="text-xs text-[var(--color-muted)] mt-0.5">{{ order.date }} · {{ order.items_count }} منتج</p>
          </div>
        </div>
        <div class="flex items-center gap-4 sm:text-end">
          <div>
            <p class="font-black text-[var(--color-primary)] dark:text-white">{{ order.total.formatted }}</p>
            <span class="inline-flex items-center gap-1 text-xs mt-1
              {% if order.status.slug == 'completed' %}text-green-600 bg-green-50 dark:bg-green-900/20
              {% elseif order.status.slug == 'cancelled' %}text-red-600 bg-red-50 dark:bg-red-900/20
              {% elseif order.status.slug == 'processing' %}text-blue-600 bg-blue-50 dark:bg-blue-900/20
              {% else %}text-yellow-600 bg-yellow-50{% endif %}
              px-2 py-0.5 rounded-full font-semibold">
              {{ order.status.name }}
            </span>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--color-muted)] rtl:rotate-180 hidden sm:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </div>
      </a>
      {% endfor %}
    </div>

    {% if orders.pages > 1 %}
    <nav class="pagination mt-10" aria-label="ترقيم الصفحات">
      {% if orders.prev_page %}<a href="{{ orders.prev_page }}" class="pagination__item">السابق</a>{% endif %}
      {% for p in 1..orders.pages %}
      {% if p == orders.current_page %}<span class="pagination__item pagination__item--active">{{ p }}</span>
      {% else %}<a href="{{ orders.page_url(p) }}" class="pagination__item">{{ p }}</a>{% endif %}
      {% endfor %}
      {% if orders.next_page %}<a href="{{ orders.next_page }}" class="pagination__item">التالي</a>{% endif %}
    </nav>
    {% endif %}

    {% else %}
    <div class="empty-state py-24">
      <svg xmlns="http://www.w3.org/2000/svg" class="empty-state__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
      <h2 class="empty-state__title">لا توجد طلبات</h2>
      <p class="empty-state__desc">لم تقم بأي طلبات بعد. ابدأ التسوق الآن!</p>
      <a href="{{ store.products_url }}" class="btn-primary btn">تسوق الآن</a>
    </div>
    {% endif %}
  </div>
</section>
{% endblock %}
