{% extends "layouts.master" %}

{% set page_title = 'حسابي' %}

{% block content %}
<div class="bg-gray-50 dark:bg-gray-800/50 border-b border-[var(--color-border)]">
  <div class="container mx-auto px-4 py-6">
    <nav class="breadcrumb" aria-label="مسار التنقل">
      <div class="breadcrumb__item"><a href="{{ store.url }}" class="breadcrumb__link">الرئيسية</a></div>
      <div class="breadcrumb__item" aria-current="page">حسابي</div>
    </nav>
    <h1 class="text-2xl md:text-3xl font-black text-[var(--color-primary)] dark:text-white mt-2">حسابي</h1>
  </div>
</div>

<section class="section">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">

      {# Sidebar Navigation #}
      <aside class="lg:col-span-1">
        <div class="card-flat rounded-[var(--border-radius-card)] overflow-hidden">
          {# User Info #}
          <div class="p-5 bg-gradient-primary text-white text-center">
            <div class="w-16 h-16 rounded-full mx-auto mb-3 overflow-hidden border-2 border-white/30">
              {% if store.customer.avatar %}
              <img src="{{ store.customer.avatar }}" alt="{{ store.customer.name }}" class="w-full h-full object-cover">
              {% else %}
              <div class="w-full h-full flex items-center justify-center bg-white/20 text-2xl font-black">
                {{ store.customer.name | first | upper }}
              </div>
              {% endif %}
            </div>
            <p class="font-bold text-sm truncate">{{ store.customer.name }}</p>
            <p class="text-white/70 text-xs truncate">{{ store.customer.email }}</p>
          </div>

          {# Nav Links #}
          <nav class="p-2" aria-label="قائمة الحساب">
            {% set nav_items = [
              { label: 'الملف الشخصي', url: store.customer.profile_url, icon: 'user' },
              { label: 'طلباتي', url: store.customer.orders_url, icon: 'bag' },
              { label: 'المفضلة', url: store.customer.wishlist_url, icon: 'heart' },
              { label: 'الإشعارات', url: store.customer.notifications_url, icon: 'bell' },
              { label: 'مكافآتي', url: store.customer.loyalty_url, icon: 'star' }
            ] %}
            {% for item in nav_items %}
            <a href="{{ item.url }}"
               class="flex items-center gap-3 px-4 py-3 rounded-[var(--border-radius)] text-sm font-medium transition-all duration-150
               {% if current_url == item.url %}bg-[var(--color-primary)] text-white{% else %}hover:bg-gray-50 dark:hover:bg-gray-700 text-[var(--color-text)]{% endif %}">
              {% if item.icon == 'user' %}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              {% elseif item.icon == 'bag' %}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
              {% elseif item.icon == 'heart' %}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
              {% elseif item.icon == 'bell' %}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
              {% elseif item.icon == 'star' %}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
              {% endif %}
              {{ item.label }}
            </a>
            {% endfor %}
            <div class="border-t border-[var(--color-border)] mt-2 pt-2">
              <a href="{{ store.customer.logout_url }}" class="flex items-center gap-3 px-4 py-3 rounded-[var(--border-radius)] text-sm font-medium text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                تسجيل الخروج
              </a>
            </div>
          </nav>
        </div>
      </aside>

      {# Main Content #}
      <div class="lg:col-span-3 space-y-6">

        {# Personal Info #}
        <div class="card-flat rounded-[var(--border-radius-card)] p-6">
          <h2 class="text-lg font-bold text-[var(--color-primary)] dark:text-white mb-5 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            المعلومات الشخصية
          </h2>
          <form action="{{ store.customer.update_profile_url }}" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <input type="hidden" name="_token" value="{{ csrf_token }}">
            <div class="form-group">
              <label for="first_name">الاسم الأول</label>
              <input type="text" id="first_name" name="first_name" value="{{ store.customer.first_name }}" class="form-control" required>
            </div>
            <div class="form-group">
              <label for="last_name">اسم العائلة</label>
              <input type="text" id="last_name" name="last_name" value="{{ store.customer.last_name }}" class="form-control" required>
            </div>
            <div class="form-group">
              <label for="email">البريد الإلكتروني</label>
              <input type="email" id="email" name="email" value="{{ store.customer.email }}" class="form-control" required>
            </div>
            <div class="form-group">
              <label for="mobile">رقم الجوال</label>
              <input type="tel" id="mobile" name="mobile" value="{{ store.customer.mobile }}" class="form-control" dir="ltr">
            </div>
            <div class="form-group md:col-span-2">
              <label for="birth_date">تاريخ الميلاد</label>
              <input type="date" id="birth_date" name="birth_date" value="{{ store.customer.birth_date }}" class="form-control">
            </div>
            <div class="md:col-span-2 flex justify-end">
              <button type="submit" class="btn-primary btn px-8">حفظ التغييرات</button>
            </div>
          </form>
        </div>

        {# Change Password #}
        <div class="card-flat rounded-[var(--border-radius-card)] p-6">
          <h2 class="text-lg font-bold text-[var(--color-primary)] dark:text-white mb-5 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
            تغيير كلمة المرور
          </h2>
          <form action="{{ store.customer.change_password_url }}" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <input type="hidden" name="_token" value="{{ csrf_token }}">
            <div class="form-group md:col-span-2">
              <label for="current_password">كلمة المرور الحالية</label>
              <input type="password" id="current_password" name="current_password" class="form-control" autocomplete="current-password">
            </div>
            <div class="form-group">
              <label for="new_password">كلمة المرور الجديدة</label>
              <input type="password" id="new_password" name="new_password" class="form-control" autocomplete="new-password" minlength="8">
            </div>
            <div class="form-group">
              <label for="confirm_password">تأكيد كلمة المرور</label>
              <input type="password" id="confirm_password" name="confirm_password" class="form-control" autocomplete="new-password">
            </div>
            <div class="md:col-span-2 flex justify-end">
              <button type="submit" class="btn-primary btn px-8">تحديث كلمة المرور</button>
            </div>
          </form>
        </div>

        {# Addresses #}
        <div class="card-flat rounded-[var(--border-radius-card)] p-6">
          <div class="flex items-center justify-between mb-5">
            <h2 class="text-lg font-bold text-[var(--color-primary)] dark:text-white flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              عناويني
            </h2>
            <a href="{{ store.customer.add_address_url }}" class="btn-outline btn-sm btn">+ إضافة عنوان</a>
          </div>
          {% if store.customer.addresses %}
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {% for address in store.customer.addresses %}
            <div class="border border-[var(--color-border)] rounded-[var(--border-radius)] p-4 relative {{ address.is_default ? 'border-[var(--color-primary)]' : '' }}">
              {% if address.is_default %}
              <span class="absolute top-3 end-3 badge badge-primary text-xs">افتراضي</span>
              {% endif %}
              <p class="font-semibold text-sm mb-1">{{ address.name }}</p>
              <p class="text-sm text-[var(--color-muted)]">{{ address.street }}</p>
              <p class="text-sm text-[var(--color-muted)]">{{ address.city }}، {{ address.country }}</p>
              {% if address.phone %}<p class="text-sm text-[var(--color-muted)]" dir="ltr">{{ address.phone }}</p>{% endif %}
              <div class="flex gap-3 mt-3 pt-3 border-t border-[var(--color-border)]">
                <a href="{{ address.edit_url }}" class="text-xs text-[var(--color-primary)] hover:underline">تعديل</a>
                <a href="{{ address.delete_url }}" class="text-xs text-red-500 hover:underline">حذف</a>
                {% if not address.is_default %}
                <a href="{{ address.set_default_url }}" class="text-xs text-[var(--color-muted)] hover:text-[var(--color-primary)]">تعيين كافتراضي</a>
                {% endif %}
              </div>
            </div>
            {% endfor %}
          </div>
          {% else %}
          <div class="text-center py-8 text-[var(--color-muted)]">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 mx-auto mb-3 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
            <p class="text-sm">لا توجد عناوين محفوظة</p>
          </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>
{% endblock %}
