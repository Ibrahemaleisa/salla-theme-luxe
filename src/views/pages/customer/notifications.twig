{% extends "layouts.master" %}
{% set page_title = 'الإشعارات' %}

{% block content %}
<div class="bg-gray-50 dark:bg-gray-800/50 border-b border-[var(--color-border)]">
  <div class="container mx-auto px-4 py-6">
    <nav class="breadcrumb"><div class="breadcrumb__item"><a href="{{ store.url }}" class="breadcrumb__link">الرئيسية</a></div><div class="breadcrumb__item" aria-current="page">الإشعارات</div></nav>
    <h1 class="text-2xl md:text-3xl font-black text-[var(--color-primary)] dark:text-white mt-2">الإشعارات</h1>
  </div>
</div>

<section class="section">
  <div class="container mx-auto px-4 max-w-3xl">
    {% if notifications.items %}
    <div class="space-y-3">
      {% for notification in notifications.items %}
      <div class="card-flat rounded-[var(--border-radius-card)] p-4 flex items-start gap-4 {{ not notification.read ? 'border-s-4 border-s-[var(--color-primary)] bg-blue-50/30 dark:bg-blue-900/10' : '' }}">
        <div class="w-10 h-10 rounded-full flex-shrink-0 flex items-center justify-center
          {% if notification.type == 'order' %}bg-blue-100 text-blue-600
          {% elseif notification.type == 'offer' %}bg-yellow-100 text-yellow-600
          {% elseif notification.type == 'success' %}bg-green-100 text-green-600
          {% else %}bg-gray-100 text-gray-600{% endif %}">
          {% if notification.type == 'order' %}
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
          {% else %}
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
          {% endif %}
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-semibold {{ not notification.read ? 'text-[var(--color-primary)] dark:text-white' : '' }}">{{ notification.title }}</p>
          <p class="text-xs text-[var(--color-muted)] mt-0.5 leading-relaxed">{{ notification.body }}</p>
          <p class="text-xs text-[var(--color-muted)] mt-2">{{ notification.date }}</p>
        </div>
        {% if not notification.read %}
        <div class="w-2 h-2 rounded-full bg-[var(--color-primary)] flex-shrink-0 mt-1.5"></div>
        {% endif %}
      </div>
      {% endfor %}
    </div>
    {% else %}
    <div class="empty-state py-24">
      <svg xmlns="http://www.w3.org/2000/svg" class="empty-state__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
      <h2 class="empty-state__title">لا توجد إشعارات</h2>
      <p class="empty-state__desc">ستظهر هنا جميع إشعاراتك حول طلباتك والعروض الجديدة.</p>
    </div>
    {% endif %}
  </div>
</section>
{% endblock %}
