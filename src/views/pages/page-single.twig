{% extends "layouts.master" %}
{% set page_title = page.title %}
{% set page_description = page.content | striptags | truncate(160) %}

{% block content %}
<div class="bg-gray-50 dark:bg-gray-800/50 border-b border-[var(--color-border)]">
  <div class="container mx-auto px-4 py-6">
    <nav class="breadcrumb"><div class="breadcrumb__item"><a href="{{ store.url }}" class="breadcrumb__link">الرئيسية</a></div><div class="breadcrumb__item" aria-current="page">{{ page.title }}</div></nav>
    <h1 class="text-2xl md:text-3xl font-black text-[var(--color-primary)] dark:text-white mt-2">{{ page.title }}</h1>
  </div>
</div>

<section class="section">
  <div class="container mx-auto px-4">
    <div class="max-w-3xl mx-auto">
      <div class="prose prose-base max-w-none dark:prose-invert
        prose-headings:text-[var(--color-primary)] dark:prose-headings:text-white
        prose-a:text-[var(--color-primary)] prose-a:no-underline hover:prose-a:underline
        prose-img:rounded-[var(--border-radius-card)] prose-img:shadow-md
        prose-blockquote:border-s-[var(--color-primary)] prose-blockquote:not-italic">
        {{ page.content | raw }}
      </div>
    </div>
  </div>
</section>

{% if page.show_comments %}
<section class="pb-16">
  <div class="container mx-auto px-4">
    <div class="max-w-3xl mx-auto">
      {% include 'components/comments' %}
    </div>
  </div>
</section>
{% endif %}
{% endblock %}
