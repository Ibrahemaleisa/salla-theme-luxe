{% extends "layouts.master" %}
{% set page_title = article.title %}
{% set page_description = article.excerpt | default(article.content | striptags | truncate(160)) %}
{% set og_image = article.image %}
{% set og_type = 'article' %}

{% block head %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "{{ article.title | escape }}",
  "description": "{{ page_description | escape }}",
  "image": "{{ article.image }}",
  "author": { "@type": "Person", "name": "{{ article.author | default(store.name) | escape }}" },
  "publisher": { "@type": "Organization", "name": "{{ store.name | escape }}", "logo": { "@type": "ImageObject", "url": "{{ theme.settings.get('logo') }}" } },
  "datePublished": "{{ article.published_at }}",
  "dateModified": "{{ article.updated_at | default(article.published_at) }}"
}
</script>
{% endblock %}

{% block content %}
{# Breadcrumb #}
<div class="bg-gray-50 dark:bg-gray-800/50 border-b border-[var(--color-border)]">
  <div class="container mx-auto px-4 py-4">
    <nav class="breadcrumb"><div class="breadcrumb__item"><a href="{{ store.url }}" class="breadcrumb__link">الرئيسية</a></div><div class="breadcrumb__item"><a href="{{ store.blog_url }}" class="breadcrumb__link">المدونة</a></div><div class="breadcrumb__item" aria-current="page">{{ article.title | truncate(40) }}</div></nav>
  </div>
</div>

<article class="section" itemscope itemtype="https://schema.org/Article">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-10">

      {# Article Content #}
      <div class="lg:col-span-3">
        {# Article Header #}
        <header class="mb-8" data-animate>
          {% if article.category %}<span class="badge badge-primary mb-4">{{ article.category }}</span>{% endif %}
          <h1 class="text-2xl md:text-4xl font-black text-[var(--color-primary)] dark:text-white leading-tight mb-4" itemprop="headline">
            {{ article.title }}
          </h1>
          <div class="flex flex-wrap items-center gap-4 text-sm text-[var(--color-muted)]">
            {% if article.author %}
            <div class="flex items-center gap-2">
              <div class="w-7 h-7 rounded-full bg-[var(--color-primary)] flex items-center justify-center text-white text-xs font-bold">{{ article.author | first | upper }}</div>
              <span itemprop="author" itemscope itemtype="https://schema.org/Person"><span itemprop="name">{{ article.author }}</span></span>
            </div>
            {% endif %}
            <time itemprop="datePublished" datetime="{{ article.published_at }}">{{ article.date }}</time>
            {% if article.read_time %}<span>{{ article.read_time }} دقائق للقراءة</span>{% endif %}
          </div>
        </header>

        {# Featured Image #}
        {% if article.image %}
        <div class="rounded-[var(--border-radius-card)] overflow-hidden mb-8 aspect-video" data-animate>
          <img src="{{ article.image }}" alt="{{ article.title }}" class="w-full h-full object-cover" loading="eager" itemprop="image">
        </div>
        {% endif %}

        {# Article Body #}
        <div class="prose prose-base max-w-none dark:prose-invert
          prose-headings:text-[var(--color-primary)] prose-headings:dark:text-white
          prose-a:text-[var(--color-primary)] prose-a:no-underline hover:prose-a:underline
          prose-img:rounded-[var(--border-radius-card)] prose-img:shadow-md
          prose-blockquote:border-s-[var(--color-primary)] prose-blockquote:bg-gray-50 dark:prose-blockquote:bg-gray-800 prose-blockquote:py-1 prose-blockquote:px-4 prose-blockquote:rounded-e-lg
          prose-code:bg-gray-100 dark:prose-code:bg-gray-800 prose-code:rounded prose-code:px-1.5 prose-code:text-[var(--color-primary)]"
          itemprop="articleBody"
        >
          {{ article.content | raw }}
        </div>

        {# Tags #}
        {% if article.tags %}
        <div class="flex flex-wrap gap-2 mt-8 pt-6 border-t border-[var(--color-border)]">
          <span class="text-sm text-[var(--color-muted)] font-medium">الوسوم:</span>
          {% for tag in article.tags %}
          <a href="{{ tag.url }}" class="badge badge-gray hover:bg-[var(--color-primary)] hover:text-white transition-colors cursor-pointer">{{ tag.name }}</a>
          {% endfor %}
        </div>
        {% endif %}

        {# Share #}
        <div class="flex items-center gap-4 mt-6 pt-6 border-t border-[var(--color-border)]">
          <span class="text-sm font-semibold text-[var(--color-muted)]">مشاركة:</span>
          <div class="flex gap-3">
            <a href="https://wa.me/?text={{ article.title | url_encode }}%20{{ current_url | url_encode }}" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-green-500 text-white flex items-center justify-center hover:bg-green-600 transition-colors" aria-label="واتساب">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </a>
            <a href="https://twitter.com/intent/tweet?text={{ article.title | url_encode }}&url={{ current_url | url_encode }}" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-black text-white flex items-center justify-center hover:bg-gray-800 transition-colors" aria-label="تويتر">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          </div>
        </div>

        {# Comments #}
        {% if article.allow_comments %}
        <div class="mt-12">
          {% include 'components/comments' %}
        </div>
        {% endif %}
      </div>

      {# Sidebar #}
      <aside class="lg:col-span-1 space-y-6">
        {# Recent Articles #}
        {% if articles.recent %}
        <div class="card-flat rounded-[var(--border-radius-card)] p-5">
          <h3 class="font-bold text-[var(--color-primary)] dark:text-white mb-4">مقالات حديثة</h3>
          <div class="space-y-4">
            {% for recent in articles.recent | slice(0, 5) %}
            <a href="{{ recent.url }}" class="flex gap-3 group">
              <div class="w-16 h-16 rounded-[var(--border-radius)] overflow-hidden flex-shrink-0 bg-gray-100">
                {% if recent.image %}
                <img src="{{ recent.image }}" alt="{{ recent.title }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform" loading="lazy">
                {% endif %}
              </div>
              <div class="min-w-0">
                <p class="text-xs font-semibold leading-snug line-clamp-2 group-hover:text-[var(--color-primary)] transition-colors">{{ recent.title }}</p>
                <p class="text-xs text-[var(--color-muted)] mt-1">{{ recent.date }}</p>
              </div>
            </a>
            {% endfor %}
          </div>
        </div>
        {% endif %}
      </aside>
    </div>
  </div>
</article>
{% endblock %}
