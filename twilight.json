          "id": "bg_image",
          "label": "صورة خلفية القسم (اختياري)",
          "type": "string",
          "format": "image"
        },
        {
          "id": "bg_dark",
          "label": "خلفية داكنة (بدلاً من الرئيسية)",
          "type": "boolean",
          "format": "switch",
          "selected": false
        }
