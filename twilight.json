      "fields": [
        {
          "id": "banners",
          "label": "البانرات",
          "type": "collection",
          "format": "collection",
          "required": true,
          "minLength": 2,
          "maxLength": 4,
          "fields": [
            {
              "id": "image",
              "label": "صورة البانر",
              "type": "string",
              "format": "image",
              "required": true
            },
            {
              "id": "title",
              "label": "عنوان البانر (اختياري)",
              "type": "string"
            },
            {
              "id": "url",
              "label": "رابط البانر",
              "type": "string",
              "format": "url",
              "required": true
            }
          ]
