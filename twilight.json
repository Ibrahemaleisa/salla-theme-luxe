          "value": "اكتشف تشكيلتنا المتنوعة"
        },
        {
          "id": "style_slider",
          "label": "عرض التصنيفات كشريط متحرك",
          "type": "boolean",
          "format": "switch",
          "selected": false
        },
        {
          "id": "style_masonry",
          "label": "عرض التصنيفات بشكل متداخل",
