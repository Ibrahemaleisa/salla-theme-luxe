      "fields": [
        {
          "id": "autoplay",
          "label": "تشغيل تلقائي للسلايدر",
          "type": "boolean",
          "format": "switch",
          "selected": true
        },
        {
          "id": "slides",
          "label": "الشرائح",
          "type": "collection",
          "format": "collection",
          "required": true,
          "minLength": 1,
          "maxLength": 5,
          "fields": [
            {
              "id": "image",
              "label": "صورة الشريحة",
              "type": "string",
              "format": "image",
              "required": true
            },
            {
              "id": "title",
              "label": "العنوان الرئيسي (اختياري)",
              "type": "string"
            },
            {
              "id": "subtitle",
              "label": "النص الوصفي (اختياري)",
              "type": "string",
              "format": "textarea"
            },
            {
              "id": "btn_text",
